# Retell AI credentials (https://dashboard.retellai.com)
RETELL_API_KEY=
RETELL_AGENT_ID=

# Public WSS hostname of this server (no trailing slash, no protocol)
# Local dev example:  random-name.trycloudflare.com
# Production example: bridge.yourdomain.com
SERVER_WSS_HOST=logging-eur-economies-continuously.trycloudflare.com

# Port this server listens on inside the container
PORT=3000

# Session TTL in minutes before an unconnected session is cleaned up
SESSION_TTL_MINUTES=60
